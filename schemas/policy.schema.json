{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w3id.org/crayon/schemas/policy.schema.json",
  "title": "Crayon governance policy (.crayon/policy.json)",
  "description": "Code-reviewed policy config consumed by `crayon check` (outline rules) and `crayon policy apply` (branch protection). Lives in the repo so policy is itself versioned and reviewable.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "outline"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "outline": {
      "type": "object",
      "additionalProperties": false,
      "description": "Heading-outline well-formedness rules enforced by `crayon check`.",
      "properties": {
        "singleTopLevel": {
          "type": "boolean",
          "default": true,
          "description": "Require exactly one top heading level per file."
        },
        "noSkippedLevels": {
          "type": "boolean",
          "default": true,
          "description": "Disallow jumps like H2 -> H4."
        },
        "maxDepth": {
          "type": "integer",
          "minimum": 1,
          "maximum": 6,
          "default": 4,
          "description": "Deepest allowed heading level."
        },
        "severity": {
          "type": "string",
          "enum": ["error", "warn"],
          "default": "error",
          "description": "Whether violations fail the check or only warn."
        }
      }
    },
    "branchProtection": {
      "type": "object",
      "additionalProperties": false,
      "description": "Declarative branch-protection state applied by `crayon policy apply`.",
      "properties": {
        "branch": { "type": "string", "default": "main" },
        "requirePullRequest": { "type": "boolean", "default": true },
        "requiredStatusChecks": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["crayon-check"],
          "description": "Status check contexts that must pass before merge."
        },
        "requiredApprovingReviews": {
          "type": "integer",
          "minimum": 0,
          "default": 1
        },
        "enforceAdmins": { "type": "boolean", "default": false }
      }
    }
  }
}
